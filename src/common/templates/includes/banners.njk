
{% from "dist/govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}

{% macro coa_designation_regulation_change(isDeparture) %}
  {% set journeyStage = "departure" if isDeparture else "arrival" %}
  <p class="govuk-body-m">
    <mark>
      The GB {{ journeyStage }} port must be officially designated to handle this flight, if you are unsure whether your intended port of departure is officially approved please visit
      <a href="https://assets.publishing.service.gov.uk/government/uploads/system/uploads/attachment_data/file/1151707/GOV.UK_GAR-Instructions-April_2023_V1.0_SDS.pdf">
        General Aviation Report (GAR) Guidance – April 2023 (publishing.service.gov.uk)
      </a> or confirm with the aerodrome authority directly.
      Only officially designated GB aerodromes are able to handle international or CTA {{ journeyStage }}s from 01/01/24.
    </mark>
  </p>
{% endmacro %}

{% macro notificationBannerForResponseCodes(numberOf0TResponseCodes, numberOf0BResponseCodes, showImportantBanner) %}
 {% if showImportantBanner or numberOf0BResponseCodes > 0 %}
 <div class="custom-govuk-notification-banner" role="region"
        aria-labelledby="govuk-notification-banner-title"
        data-module="custom-govuk-notification-banner">
        <div class="govuk-notification-banner__header">
            <h2 class="govuk-notification-banner__title" id="govuk-notification-banner-title">
            Important
            </h2>
        </div>
        {% if numberOf0TResponseCodes > 0 and showImportantBanner %}
        <div class="govuk-notification-banner__content">
            <p class="govuk-body">
             <strong>{{numberOf0TResponseCodes}} {% if numberOf0TResponseCodes == 1 %} person has{% else %} people have{% endif %} a 'system time out' status.</strong>
            This means we were unable to check their digital permission to travel.
            </p>
            <p class="govuk-body">
              You should <a href="#" id="resubmit0T" class="govuk-link resubmit0T">resubmit digital permission to travel checks</a>
               for them if your expected time of departure is more than 2 hours 5 minutes in the future, otherwise you can continue to submit your GAR.
            </p>
        </div>
        {% endif %}
        {% if numberOf0BResponseCodes > 0 %}
        <div class="govuk-notification-banner__content">
            <p class="govuk-body">
            <strong>{{numberOf0BResponseCodes}} {% if numberOf0BResponseCodes == 1 %} person has{% else %} people have{% endif %} 'no record of valid permission to travel'.</strong>
            This means we have no record of a digital permission for them.
            </p>
            <p class="govuk-body">
            You need to manually check that they have a valid permission to travel to the UK.
            </p>
        </div>
        {% endif %}
  </div>
 {% endif %}
{% endmacro %}

{% macro id_card_withdrawl_text(__) %}
  <div class="govuk-inset-text">
    {{ __('id_card_withdrawl_text') }}
    <a class="govuk-link" href="https://www.gov.uk/guidance/visiting-the-uk-as-an-eu-eea-or-swiss-citizen">GOV.UK</a>.
  </div>
{% endmacro %}
