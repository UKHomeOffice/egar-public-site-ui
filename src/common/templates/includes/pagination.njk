{#
Macro representing the pagination component, takes the form name which when
submitted results in page transitions, and the pages object, an object returned
from the pagination.js build function. The i18n __ reference also needs to be
passed in explicitly it seems.
#}

{% macro build(formName, pages, __) %}
  <nav class="govuk-pagination" role="navigation" aria-label="Pagination Navigation" aria-labelledby="{{ formName }}">
    <script type="text/javascript">
      function transitionToPage(pageNumber) {
        nextPage=document.createElement('input');
        nextPage.type='hidden';
        nextPage.name='nextPage';
        nextPage.value=pageNumber;
        document.getElementById('{{ formName }}').appendChild(nextPage);
        document.getElementById('{{ formName }}').submit();
        return false;
      }
    </script>
    
    {% if pages.totalPages > 1 %}
      <ul class="govuk-pagination__list">

        {% if pages.currentPage > 1 %}
          <li class="govuk-pagination__prev">
            <a class="govuk-link govuk-pagination__link" onclick="transitionToPage({{ pages.currentPage - 1 }})" aria-label="Previous page">
            <svg class="govuk-pagination__icon govuk-pagination__icon--prev" xmlns="http://www.w3.org/2000/svg" height="13" width="15" aria-hidden="true" focusable="false" viewBox="0 0 15 13">
              <path d="m6.5938-0.0078125-6.7266 6.7266 6.7441 6.4062 1.377-1.449-4.1856-3.9768h12.896v-2h-12.984l4.2931-4.293-1.414-1.414z"></path>
            </svg>
            <span class="govuk-pagination__link-title" aria-hidden="true" role="presentation">{{__('pagination_previous')}}</span>
            </a>
            
          </li>
        {% endif %}
        
        {% for pageNumber in pages.items %}
          {% if pageNumber === pages.currentPage %}
            <li class="govuk-pagination__item govuk-pagination__item--current">
              <a id="{{formName}}_pagination_{{pageNumber}}" class="govuk-link govuk-pagination__link" href="" aria-current="true" aria-label="Page {{ pageNumber }}, current page">{{ pageNumber }}</a>
            </li>
          {% else %}
            <li class="govuk-pagination__item">
              <a id="{{formName}}_pagination_{{pageNumber}}" class="govuk-link govuk-pagination__link" onclick="transitionToPage({{ pageNumber }})" aria-label="Go to page {{ pageNumber }}">{{ pageNumber }}</a>
            </li>
          {% endif %}
        {% endfor %}
        
        {% if pages.currentPage < pages.totalPages %}
          <li class="govuk-pagination__next">
            <a class="govuk-link govuk-pagination__link" onclick="transitionToPage({{ pages.currentPage + 1 }})" aria-label="Next page">
              <span class="govuk-pagination__link-title" aria-hidden="true" role="presentation">
                {{__('pagination_next')}}
              </span> 
              <svg class="govuk-pagination__icon govuk-pagination__icon--next" xmlns="http://www.w3.org/2000/svg" height="13" width="15" aria-hidden="true" focusable="false" viewBox="0 0 15 13">
                <path d="m8.107-0.0078125-1.4136 1.414 4.2926 4.293h-12.986v2h12.896l-4.1855 3.9766 1.377 1.4492 6.7441-6.4062-6.7246-6.7266z"></path>
              </svg>
            </a>
          </li>
        {% endif %}
      </ul>
      
      <p class="govuk-body">Showing {{ pages.startItem }} &ndash; {{ pages.endItem }} of {{ pages.totalItems }} results </p> 
    {% endif %}
  </nav>
{% endmacro %}
