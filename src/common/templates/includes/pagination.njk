{% from "dist/govuk/components/pagination/macro.njk" import govukPagination %}
  
{% macro build(formName, pages, __) %}

{% block content %}
<script src="/javascripts/pagination.js" type="text/javascript"></script>

{% set pageList = [] %}
{% set previousItem = null %}
{% set nextItem = null %}

{% if pages.currentPage > 1 %}
  {% set previousItem = {
    href: "#",
    attributes: {
      onclick: "return transitionToPage(" + (pages.currentPage  - 1) + ", '" + formName + "')"
    }
  } %}
{% endif %}

{% if pages.currentPage < pages.totalPages %}
  {% set nextItem = {
    href: "#",
    attributes: {
      onclick: "return transitionToPage(" + (pages.currentPage + 1) + ", '" + formName + "')"
    }
  } %}
{% endif %}

{% if pages.items.length > 1 %}
  {% for pageNumber in pages.items %}
    {% set items = pageList.push({
        number: pageNumber,
        href: "#",
        current: pageNumber === pages.currentPage,
        attributes: {
          onclick: "return transitionToPage(" + pageNumber + ", '" + formName + "')"
        }
      }) 
    %}
  {% endfor %}
{% endif %} 





<div class="govuk-grid-row pagination-wrapper">
  <div class="govuk-grid-column-one-half">
    {% if pages.totalPages > 1 %}
      {{ govukPagination({
        previous: previousItem,  
        next: nextItem,
        items: pageList
      }) }}
    {% endif %}
  </div>
  <div class="govuk-grid-column-one-half">
    <p class="govuk-body-m govuk-!-text-align-right">
      Showing {{ pages.startItem }} &ndash; {{ pages.endItem }} of {{ pages.totalItems }} results
    </p>
  </div>
</div>

{% endblock %}
{% endmacro %}
