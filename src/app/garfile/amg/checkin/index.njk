{% extends "base-template.njk" %}

{% import "common/templates/includes/macros.njk" as m %}
{% import "common/templates/includes/banners.njk" as banner %}

{% block pageTitle %}
  {{__('error_prefix') if errors}} Create GAR | Passenger Check
{% endblock %}

{% set active = '/home' %}

{% block content %}
  <link rel="stylesheet" href="/stylesheets/amg.css"/> 
  <div id="checkinpage">
     <div id="top-notification-banner"></div> 

      <span class="govuk-caption-xl">{{__('section_count', 9, 9)}}</span>
      <h1 class="govuk-heading-xl">{{__('title_submit_gar_amg')}}</h1>
     
      <div>
       <p class="govuk-body">Before travelling, you should check the digital permission to travel result for each person to see if manual permission to travel checks are needed. 
        Find out more about how to <a class="govuk-link" href="/help#details-content-documents" target="_blank">check permission to travel (opens in new tab)</a> in the help guidance.
        </p>
        <p class="govuk-body">You must also check each person has a 
         <a class="govuk-link" href="https://www.gov.uk/government/publications/recognising-fraudulent-identity-documents" target="_blank">genuine and valid passport or travel document (opens in a new tab on GOV.UK)</a> and that they are the rightful holder. You will remain liable for any penalties relating to a failure to adequately conduct these checks.
        </p>
      </div>
      <div id="pane">
        {% include "app/garfile/amg/checkin/pane.njk" %}
      </div>
    </div>
  </div>
  <input type="hidden" value="{{resubmitted}}" id='resubmitted' />
  <form id="reSubmitGarForm" action="/garfile/review" method="post">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}"/>
    <input type="hidden" name="resubmitFor0T" value="resubmit0T" />
    <input type="hidden" name="resubmitFor0TLink" id="resubmitFor0TLink" value="no" />
  </form>
{% endblock content %}
