{% from "dist/govuk/components/button/macro.njk" import govukButton %}
{% from "dist/govuk/components/panel/macro.njk" import govukPanel %}

<div class="govuk-body govuk-grid-column-two-thirds govuk-!-margin-left-8 govuk-!-margin-top-4">

  <div class="govuk-width-container govuk-!-margin-bottom-4">
    {{ govukPanel({titleHtml: "Account has been <br/> created"}) }}
  </div>

  <p>We have sent you a confirmation email</p>

  <h1 class="govuk-heading-l">What happens next</h1>

  <div class="govuk-!-margin-bottom-7">
    <p>You can use the service to:</p>

    <ul class="govuk-list govuk-list--bullet govuk-!-margin-bottom-4 govuk-!-padding-left-7">
      <li>submit a GAR</li>
      <li>view, edit or cancel a GAR</li>
      <li>add, remove or manage people on your flight</li>
    </ul>
  </div>

  <form method="post" action="/onelogin/register" novalidate>
    <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
    {{ govukButton({text: "Continue", element: "button", type: "submit"}) }}
  </form>

</div>
